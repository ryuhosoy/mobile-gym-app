{
  "expo": {
    "name": "ジム検索アプリ",
    "slug": "react-native-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_1024x1024.png",
    "scheme": "gymapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "近くのジムを検索できるアプリ",
    "category": "health-fitness",
    "keywords": ["ジム", "フィットネス", "予約", "検索"],
    "privacy": "public",
    "primaryLanguage": "ja",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ryuhosoy.gym-app",
      "displayName": "ジム検索アプリ",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "近くのジムを検索するために位置情報を使用します",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "近くのジムを検索するために位置情報を使用します"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "jsEngine": "hermes",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1997f5ea-4872-4fb6-b11c-1e46293411f5"
      }
    }
  }
}
